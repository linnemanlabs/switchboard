{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linnemanlabs.com/schemas/runbook-proposal.schema.json",
  "title": "Runbook Proposal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "proposal_id",
    "incident_id",
    "correlation_id",
    "runbook_id",
    "runbook_version",
    "status",
    "proposed_by",
    "proposed_at",
    "parameters",
    "target_selector",
    "reasoning_summary",
    "evidence_refs",
    "required_reviews"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "proposal_id": {
      "type": "string",
      "format": "uuid"
    },
    "incident_id": {
      "type": "string",
      "format": "uuid"
    },
    "correlation_id": {
      "type": "string",
      "format": "uuid"
    },
    "runbook_id": {
      "type": "string"
    },
    "runbook_version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "under_review",
        "approved",
        "rejected",
        "expired",
        "cancelled",
        "executed"
      ]
    },
    "proposed_by": {
      "$ref": "#/$defs/actor"
    },
    "proposed_at": {
      "type": "string",
      "format": "date-time"
    },
    "parameters": {
      "type": "object",
      "description": "Runbook-specific parameters."
    },
    "target_selector": {
      "type": "object",
      "description": "How the intended targets are described or selected."
    },
    "reasoning_summary": {
      "type": "string"
    },
    "confidence": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 1
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      }
    },
    "detection_hints": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "hard_constraints": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "verification_checks": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "estimated_blast_radius": {
      "$ref": "#/$defs/blastRadius"
    },
    "blocking_risks": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "rollback_summary": {
      "type": [
        "string",
        "null"
      ]
    },
    "required_reviews": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "rule_based",
          "agent_based",
          "human"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "metadata": {
      "type": "object"
    }
  },
  "$defs": {
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "id"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "service",
            "agent",
            "user"
          ]
        },
        "id": {
          "type": "string"
        },
        "display_name": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref"
      ],
      "properties": {
        "ref": {
          "type": "string"
        },
        "kind": {
          "type": [
            "string",
            "null"
          ]
        },
        "summary": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "blastRadius": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level"
      ],
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "unknown"
          ]
        },
        "scope_summary": {
          "type": [
            "string",
            "null"
          ]
        },
        "rationale": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
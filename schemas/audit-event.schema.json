{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linnemanlabs.com/schemas/audit-event.schema.json",
  "title": "Audit Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "event_type",
    "event_version",
    "occurred_at",
    "correlation_id",
    "actor",
    "payload"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "event_type": {
      "type": "string",
      "pattern": "^[a-z0-9]+(\\.[a-z0-9-]+)+$",
      "description": "Examples: alert.received, tool.called, runbook.proposed"
    },
    "event_version": {
      "type": "integer",
      "minimum": 1
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "correlation_id": {
      "type": "string",
      "format": "uuid"
    },
    "incident_id": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "actor": {
      "$ref": "#/$defs/actor"
    },
    "subject": {
      "anyOf": [
        {
          "$ref": "#/$defs/subject"
        },
        {
          "type": "null"
        }
      ]
    },
    "payload": {
      "type": "object",
      "description": "Event-specific payload under a common envelope."
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      },
      "default": []
    },
    "policy_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      },
      "default": []
    },
    "integrity": {
      "anyOf": [
        {
          "$ref": "#/$defs/integrity"
        },
        {
          "type": "null"
        }
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  },
  "$defs": {
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "id"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "user",
            "service",
            "agent",
            "reviewer",
            "executor",
            "tool",
            "system"
          ]
        },
        "id": {
          "type": "string",
          "description": "Prefer SPIFFE ID for internal services when available."
        },
        "display_name": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "id"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "incident",
            "alert",
            "tool_call",
            "tool_result",
            "investigation",
            "runbook_proposal",
            "review",
            "transparency_record",
            "execution_request",
            "execution_result"
          ]
        },
        "id": {
          "type": "string"
        }
      }
    },
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref"
      ],
      "properties": {
        "ref": {
          "type": "string"
        },
        "kind": {
          "type": [
            "string",
            "null"
          ]
        },
        "summary": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hash": {
          "type": [
            "string",
            "null"
          ]
        },
        "prev_event_hash": {
          "type": [
            "string",
            "null"
          ]
        },
        "signature_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "tsa_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "transparency_log_ref": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linnemanlabs.com/schemas/execution-result.schema.json",
  "title": "Execution Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "execution_result_id",
    "execution_request_id",
    "proposal_id",
    "incident_id",
    "correlation_id",
    "runbook_id",
    "runbook_version",
    "executor",
    "started_at",
    "completed_at",
    "duration_ms",
    "status",
    "target_results",
    "verification_results"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "execution_result_id": {
      "type": "string",
      "format": "uuid"
    },
    "execution_request_id": {
      "type": "string",
      "format": "uuid"
    },
    "proposal_id": {
      "type": "string",
      "format": "uuid"
    },
    "incident_id": {
      "type": "string",
      "format": "uuid"
    },
    "correlation_id": {
      "type": "string",
      "format": "uuid"
    },
    "runbook_id": {
      "type": "string"
    },
    "runbook_version": {
      "type": "string"
    },
    "executor": {
      "$ref": "#/$defs/actor"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0
    },
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "completed_with_warnings",
        "failed",
        "partial",
        "cancelled",
        "blocked"
      ]
    },
    "status_summary": {
      "type": [
        "string",
        "null"
      ],
      "description": "Short human-readable summary of the overall result."
    },
    "dry_run": {
      "type": "boolean",
      "default": false
    },
    "resolved": {
      "type": [
        "boolean",
        "null"
      ],
      "description": "Whether the execution appears to have resolved the original issue."
    },
    "precondition_results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/checkResult"
      },
      "default": []
    },
    "target_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/targetResult"
      }
    },
    "verification_results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/checkResult"
      }
    },
    "error": {
      "anyOf": [
        {
          "$ref": "#/$defs/error"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "output_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      },
      "default": [],
      "description": "References to stored stdout, logs, artifacts, or other detailed execution output."
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reference"
      },
      "default": [],
      "description": "References to evidence gathered during or after execution."
    },
    "rollback_recommended": {
      "type": "boolean",
      "default": false
    },
    "rollback_summary": {
      "type": [
        "string",
        "null"
      ]
    },
    "metadata": {
      "type": "object",
      "default": {}
    }
  },
  "$defs": {
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "id"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "service",
            "executor",
            "system"
          ]
        },
        "id": {
          "type": "string",
          "description": "Prefer SPIFFE ID for internal services when available."
        },
        "display_name": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "checkResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "status"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "failed",
            "warning",
            "not_run",
            "unknown"
          ]
        },
        "summary": {
          "type": [
            "string",
            "null"
          ]
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reference"
          },
          "default": []
        }
      }
    },
    "targetResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_id",
        "status"
      ],
      "properties": {
        "target_id": {
          "type": "string"
        },
        "target_type": {
          "type": [
            "string",
            "null"
          ],
          "description": "Examples: host, instance, node, service member, ring entry"
        },
        "status": {
          "type": "string",
          "enum": [
            "completed",
            "failed",
            "skipped",
            "blocked",
            "unknown"
          ]
        },
        "summary": {
          "type": [
            "string",
            "null"
          ]
        },
        "changed": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "output_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reference"
          },
          "default": []
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reference"
          },
          "default": []
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message",
        "retryable"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "retryable": {
          "type": "boolean"
        },
        "details": {
          "type": [
            "object",
            "null"
          ]
        }
      }
    },
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref"
      ],
      "properties": {
        "ref": {
          "type": "string"
        },
        "kind": {
          "type": [
            "string",
            "null"
          ]
        },
        "summary": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "enum": [
              "failed",
              "blocked"
            ]
          }
        }
      },
      "then": {
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "$ref": "#/$defs/error"
          }
        }
      }
    }
  ]
}